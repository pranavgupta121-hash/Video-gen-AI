rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'pranavgupta121@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidUserActivity(data) {
      return data.keys().hasAll(['action', 'timestamp']) &&
             data.action is string && data.action.size() <= 100 &&
             data.timestamp is timestamp &&
             (data.get('userId', null) == null || data.userId is string) &&
             (data.get('status', null) == null || data.status in ['success', 'failed', 'pending']) &&
             (data.get('userAgent', null) == null || data.userAgent is string);
    }

    match /logs/{logId} {
      allow create: if isValidId(logId) && isValidUserActivity(request.resource.data);
      allow get, list: if isAdmin();
      allow update, delete: if false; // Logs should be immutable
    }
  }
}
